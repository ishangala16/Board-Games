{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "module": "commonjs",
        "moduleResolution": "node",
        "target": "es2019",
        "isolatedModules": false,
        "noEmit": false
    },
    "include": [
        "server.ts",
        "lib/**/*.ts"
    ],
    "exclude": [
        "node_modules",
        ".next"
    ]
}