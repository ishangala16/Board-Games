datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  username  String   @unique
  email     String?  @unique
  createdAt DateTime @default(now())
  
  gamesAsPlayer1 GameSession[] @relation("Player1")
  gamesAsPlayer2 GameSession[] @relation("Player2")
  wins           GameSession[] @relation("Winner")
}

model GameSession {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  gameType  String   // "SEQUENCE", "SPLENDOR"
  status    String   // "LOBBY", "ACTIVE", "COMPLETED"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  player1Id String   @db.ObjectId
  player1   User     @relation("Player1", fields: [player1Id], references: [id])
  player2Id String?  @db.ObjectId
  player2   User?    @relation("Player2", fields: [player2Id], references: [id])
  
  winnerId  String?  @db.ObjectId
  winner    User?    @relation("Winner", fields: [winnerId], references: [id])

  currentGameState Json 
  moves Move[]
}

model Move {
  id            String      @id @default(auto()) @map("_id") @db.ObjectId
  gameId        String      @db.ObjectId
  game          GameSession @relation(fields: [gameId], references: [id])
  playerId      String      @db.ObjectId
  actionType    String
  payload       Json
  createdAt     DateTime    @default(now())
}
